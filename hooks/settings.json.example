{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "~/.superclaw/hooks/superclaw-notify.sh",
        "timeout": 30
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "~/.superclaw/hooks/superclaw-progress.sh",
        "timeout": 10
      }
    ]
  }
}
